DB_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/multi_agent
AGENT_API_KEY=your-secret-key-here
NEWS_API_KEY=your-newsapi-key-here

A2A_ENABLE_PUSH=0
A2A_PUBLIC_URL=https://your-app.railway.app
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

MCP_HOST=127.0.0.1
MCP_PORT=8001
MCP_TRANSPORT=stdio

RD_TIMEOUT=10
SENTI_TIMEOUT=10
SENTI_SLEEP_MS=120
SENTI_ENDPOINT=https://sentim-api.herokuapp.com/api/v1/
REDDIT_SUBS=stocks,wallstreetbets,investing
SENTI_MIN_SUCCESS=5
SENTI_RETRY=1
